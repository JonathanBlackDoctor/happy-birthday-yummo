{
  "name": "kmu-vn",
  "private": true,
  "version": "0.1.0",
  "description": "구연시: 본과 1학년의 봄 — kmu-vn engine skeleton (W4)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "compile": "tsx scripts/compile-scene.ts",
    "compile:compressed": "tsx scripts/compile-scene.ts --mode=compressed",
    "compile:all": "npm run compile && npm run compile:compressed",
    "validate": "tsx scripts/validate-build.ts",
    "validate:compressed": "tsx scripts/validate-compressed.ts",
    "manifest": "tsx scripts/build-manifest.ts",
    "generate:ending-square": "tsx scripts/generate-ending-square.ts"
  },
  "dependencies": {
    "howler": "^2.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.48.0",
    "@types/howler": "^2.2.12",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.13",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.0"
  }
}
