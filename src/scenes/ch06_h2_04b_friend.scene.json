      "transition": "fade"
    },
    {
      "type": "DIALOGUE",
      "speaker": "윤하정",
      "text": "...어, 그래."
    },
    {
      "type": "DIALOGUE",
      "speaker": "윤하정",
      "text": "친구. 그래 친구로."
