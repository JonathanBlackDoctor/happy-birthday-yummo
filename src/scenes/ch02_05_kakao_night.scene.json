        {
          "sender": "정욱",
          "text": "ㄴㄴㄴ"
        },
        {
          "sender": "윤하정",
          "text": "ㅋㅋ 됐고"
        },
        {
          "sender": "윤하정",
          "text": "조교님이 다 정리해주셨잖아"
        },
        {
          "sender": "오준혁",
          "text": "한설 조교님 진짜 침착하셨음"
        },
        {
          "sender": "이문규",
          "text": "ㅇㅇ"
        },
        {
          "sender": "구윤모",
          "text": "다음엔 안 깸"
        },
        {
          "sender": "구윤모",
          "text": "약속함"
        },
        {
          "sender": "정욱",
          "text": "약속을 깨면 안 되지"
