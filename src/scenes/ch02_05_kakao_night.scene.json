        {
          "sender": "구윤모",
          "text": "어"
        },
        {
          "sender": "구윤모",
          "text": "같이 가면 되는 거지"
        },
        {
          "sender": "윤하정",
          "text": "알겠어"
        },
        {
          "sender": "윤하정",
          "text": "자라"
        },
        {
          "sender": "구윤모",
          "text": "그래"
        },
        {
          "sender": "구윤모",
          "text": "너도"
