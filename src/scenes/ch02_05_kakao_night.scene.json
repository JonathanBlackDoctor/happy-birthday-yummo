        },
        {
          "sender": "구윤모",
          "text": "ㄷㄷ"
        },
        {
          "sender": "구윤모",
          "text": "소문 빠름"
        },
        {
          "sender": "정욱",
          "text": "다음 실험 누구랑 자리 바꿔야 할 듯"
        },
        {
          "sender": "오준혁",
          "text": "ㅋㅋㅋㅋ 정욱이 옆 가서 잡아주면 됨"
