    {
      "type": "SFX",
      "sound": "sfx_katalk_notify"
    },
    {
      "type": "NARRATION",
      "text": "5조 단톡방. \"본과 1학년 해부 5조\"."
    },
    {
      "type": "KAKAO",
      "messages": [
        {
          "sender": "오준혁",
          "text": "윤모 살아 있냐"
