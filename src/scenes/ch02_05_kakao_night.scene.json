        {
          "sender": "윤하정",
          "text": "어제 무거웠고 오늘 깨먹고"
        },
        {
          "sender": "구윤모",
          "text": "그건 좀 묻어줘라"
        },
        {
          "sender": "윤하정",
          "text": "못 묻어줌"
        },
        {
          "sender": "윤하정",
          "text": "근데 어제는 진짜"
        },
        {
          "sender": "윤하정",
          "text": "...너 옆에 있어줘서 덜 무서웠음"
